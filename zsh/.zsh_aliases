# ╚══███╔╝██╔════╝██║  ██║        ██╔══██╗██║     ██║██╔══██╗██╔════╝██╔════╝██╔════╝
#   ███╔╝ ███████╗███████║        ███████║██║     ██║███████║███████╗█████╗  ███████╗
#  ███╔╝  ╚════██║██╔══██║        ██╔══██║██║     ██║██╔══██║╚════██║██╔══╝  ╚════██║
# ███████╗███████║██║  ██║███████╗██║  ██║███████╗██║██║  ██║███████║███████╗███████║
# ╚══════╝╚══════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝╚══════╝╚═╝╚═╝  ╚═╝╚══════╝╚══════╝╚══════╝

alias c=clear
alias p=pwd
alias e=exit
alias ipd='ifconfig'
alias r='cd -'
alias ..='cd ..'
alias pi="ps -e | grep -i "
alias inf="ls -lFh | grep -i "

# Check if 'bat' command exists once
if command -v bat >/dev/null 2>&1; then
  # If 'bat' exists, alias 'cat' to 'bat'
  alias catn='bat --paging never -f'
  alias cat='bat --style plain --paging never -f'
fi

# Check if 'eza' command exists once
if command -v eza &> /dev/null; then
    alias l1='eza -lhF --tree --level=2'
    alias l2='eza -lhF --tree --level=3'

    alias ls='eza -F --color=always --icons'
    alias lsa='eza -aF --color=always --icons'

    alias ll='eza -lF --color=always --icons --bytes'
    alias llh='eza -lhF --color=always --icons'

    alias lla='eza -laF --color=always --icons --bytes'
    alias llah='eza -lahF --color=always --icons'

    alias llg='eza -lhF --color=always --icons --group-directories-first'
    alias llga='eza -lahF --color=always --icons --group-directories-first'

    alias llt='eza -lhF --color=always --icons  --sort modified'
    alias llta='eza -lahF --color=always --icons  --sort modified'
else
    alias ls='ls -F'
    alias lsa='ls -aF'

    alias ll='ls -lF'
    alias llh='ls -lhF'

    alias lla='ls -alF'
    alias llah='ls -alhF'

    alias llt='ls -hlFtr'
    alias llta='ls -halFtr'
fi

# Detect editor
if command -v code >/dev/null 2>&1; then
  EDITOR_CMD="code"
  EDITOR_BG="yes"
else
  EDITOR_CMD="vim"
  EDITOR_BG="no"
fi

open_cfg() {
  if [ "$EDITOR_BG" = "yes" ]; then
    ( "$EDITOR_CMD" "$1" & ) > /dev/null 2>&1
  else
    "$EDITOR_CMD" "$1"
  fi
}

alias OA='open_cfg ~/.config/zsh/.zsh_aliases'

if [ -n "$BASH_VERSION" ]; then
  alias OB='open_cfg ~/.bashrc'
  alias OBP='open_cfg ~/.bash_profile'
  alias BR='source ~/.bashrc'
elif [ -n "$ZSH_VERSION" ]; then
  alias OB='open_cfg ~/.config/zsh/.zshrc'
  alias OBP='open_cfg ~/.config/zsh/.zsh_functions'
  alias ZR='source ~/.config/zsh/.zshrc'
fi

alias nb='( jupyter notebook & ) > /dev/null 2>&1'
alias gss="git status"
alias gmeld="git difftool -t meld"
alias ATC='~/.config/alacritty/themes/theme_change.sh && ~/.config/alacritty/themes/print_colors.sh'

